// 마음이음 - PostgreSQL (AWS RDS + pgvector 예정)
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

// NextAuth
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?   // credentials 로그인용 해시
  image         String?
  age           Int?      // 연령 (호칭 추론용)
  gender        String?   // "male" | "female" | "other" (호칭 추론용)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  conversations Conversation[]
  healthLogs    HealthLog[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at       Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

// 대화: 사용자당 1개만 존재 (오랜 기간 데이터 누적)
model Conversation {
  id        String   @id @default(cuid())
  userId    String   @unique
  title     String?  @default("새 대화")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   Message[]
  healthLogs HealthLog[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user" | "assistant" | "system"
  content        String
  isAnomaly      Boolean? @default(false) // AI가 감지한 인지/상황 이상 징후 여부
  analysisNote   String?  // 이상 징후에 대한 AI 분석 메모 (참고용)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// 식사·기분·인지 등 참고용 건강/일상 로그 (의료 진단 아님)
model HealthLog {
  id             String   @id @default(cuid())
  userId         String
  conversationId String?
  type           String   // "meal" | "mood" | "cognitive" | "activity" | "etc"
  value          String?  // 예: "아침 식사 함", "좋음", "날씨 인지 오류"
  note           String?  // 추가 메모
  createdAt      DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
}
